# Provider secrets/URLs. These are read by NAME in the instance loader, not as
# Settings fields. An instance is enabled only when its variable(s) are set; the
# pipeline needs at least one SEARCH and one READ provider. Placeholders only —
# never commit real keys.

# --- Search providers (need >= 1) ---
SEARXNG_URL=http://searxng:8080          # SearXNG metasearch base URL
SERPER_API_KEY=your_serper_key           # optional: Serper Google Search API key
EXA_API_KEY=your_exa_key                 # optional: Exa search API key

# --- Read providers ---
# trafilatura needs no config and is always on (first in the read pipeline).
JINA_API_KEY=your_jina_key               # optional: Jina Reader (works keyless at lower rate)
CRAWL4AI_URL=http://crawl4ai:11235       # optional: self-hosted Crawl4AI base URL
CRAWL4AI_TOKEN=your_crawl4ai_token       # required IF CRAWL4AI_URL is set (Bearer token)
TAVILY_1_API_KEY=your_tavily_key_1       # optional: Tavily Extract key (primary)
TAVILY_2_API_KEY=your_tavily_key_2       # optional: Tavily Extract key (failover)
FIRECRAWL_API_KEY=your_firecrawl_key     # optional: Firecrawl v2 scrape API key

# --- MCP transport (streamable-http; endpoint /mcp). Defaults are fine. ---
MCP_HOST=0.0.0.0
MCP_PORT=8000

# --- Behaviour knobs (defaults are fine). ---
LOG_LEVEL=INFO
REQUEST_TIMEOUT=25.0                      # httpx timeout, seconds
FALLBACK_MIN_CHARS=400                    # read content shorter than this → next provider
READ_PAGES_CONCURRENCY=5                  # concurrent reads in read_pages
# Note: the read_pages per-call url cap is a fixed 20 (hard constant in code,
# matching the tool description) — not configurable here.
RETRIES=1                                 # extra retries on transient HTTP failures
